# ─── AI Configuration ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Service URLs ──────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:3001
AGENT_URL=http://localhost:3002
NEXT_PUBLIC_AGENT_URL=http://localhost:3002

# ─── MCP Server ───────────────────────────────────────────────────────────
MCP_HTTP_PORT=3001

# ─── Agent ────────────────────────────────────────────────────────────────
AGENT_PORT=3002

# ─── AWS (for CloudWatch logs) ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── GitHub (for deployment history) ─────────────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
GITHUB_ORG=your-org

# ─── Databases ────────────────────────────────────────────────────────────
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=production_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=production_db
MYSQL_USER=app_user
MYSQL_PASSWORD=

# MongoDB
MONGO_URI=mongodb://localhost:27017

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Log Paths ────────────────────────────────────────────────────────────
LOG_BASE_PATH=/var/log
PM2_LOG_PATH=/root/.pm2/logs

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
