# Run this to create it
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
dist/
build/
out/

# Environment — NEVER commit these
.env
.env.local
.env.*.local
*.env

# Logs
*.log
npm-debug.log*
.npm/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# TypeScript
*.tsbuildinfo

# Misc
.turbo/
coverage/
EOF